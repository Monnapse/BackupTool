# ── BackupTool configuration ───────────────────────────────────────────────

# Port the dashboard listens on (host + container). Change this freely.
# Default is an uncommon port to avoid clashing with other services.
PORT=8723

# Admin dashboard password (required). Change this!
ADMIN_PASSWORD=change-me-please

# Secret used to sign session cookies AND encrypt stored credentials at rest.
# Generate a long random string, e.g.  openssl rand -hex 32
APP_SECRET=please-generate-a-long-random-secret-string

# Set to "true" ONLY if you serve the dashboard over HTTPS (e.g. behind a
# reverse proxy with TLS). Leave false for plain-HTTP LAN access, otherwise the
# browser drops the login cookie and you can never sign in.
COOKIE_SECURE=false

# Where the SQLite config database lives (inside the container).
DATA_DIR=/data

# Default directory for the "Local / mounted drive" destination.
# Mount your SD card / USB drive here in docker-compose.
BACKUP_DIR=/backups

# How to reach the Docker daemon.
#  - Linux/macOS: unix socket (default below)
#  - Windows host: tcp://host.docker.internal:2375  (enable "Expose daemon" in Docker Desktop)
DOCKER_SOCKET=/var/run/docker.sock

# Public base URL of this app — used to build the OAuth redirect URIs you
# register with Google/Dropbox. Set this to how you actually reach the app
# (e.g. http://192.168.1.50:8723 or https://backup.example.com).
APP_URL=http://localhost:8723

# Optional: restrict the local drive browser to a single root path. Leave unset
# to browse all drives/mounts the app can see.
# FS_BROWSE_ROOT=/backups

# ── Cloud accounts: NO env needed ──────────────────────────────────────────
# Google Drive and Dropbox are linked entirely in the website: add the
# destination, paste your OAuth app's Client ID/Secret in the form, click
# "Link account", then pick a folder. The values below are an OPTIONAL fallback
# (a default app used when a destination has no credentials of its own).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# DROPBOX_CLIENT_ID=
# DROPBOX_CLIENT_SECRET=
