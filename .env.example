# ── BackupTool configuration ───────────────────────────────────────────────

# Admin dashboard password (required). Change this!
ADMIN_PASSWORD=change-me-please

# Secret used to sign session cookies AND encrypt stored credentials at rest.
# Generate a long random string, e.g.  openssl rand -hex 32
APP_SECRET=please-generate-a-long-random-secret-string

# Where the SQLite config database lives (inside the container).
DATA_DIR=/data

# Default directory for the "Local / mounted drive" destination.
# Mount your SD card / USB drive here in docker-compose.
BACKUP_DIR=/backups

# How to reach the Docker daemon.
#  - Linux/macOS: unix socket (default below)
#  - Windows host: tcp://host.docker.internal:2375  (enable "Expose daemon" in Docker Desktop)
DOCKER_SOCKET=/var/run/docker.sock

# ── Google Drive (optional) ────────────────────────────────────────────────
# Create an OAuth 2.0 Client (type: Web application) in Google Cloud Console.
# Authorized redirect URI must be:  <your-app-url>/api/destinations/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Dropbox (optional) ─────────────────────────────────────────────────────
# Create an app at https://www.dropbox.com/developers/apps (scoped, files.content.write)
# Redirect URI:  <your-app-url>/api/destinations/oauth/dropbox/callback
DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=

# Public base URL of this app (used to build OAuth redirect URIs).
APP_URL=http://localhost:3000
